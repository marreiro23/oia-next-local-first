{
  "name": "rag-api",
  "version": "1.0.0",
  "description": "RAG Pipeline — NestJS 11 + pgvector + Ollama (local)",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "compose:up": "docker compose -f ../../docker-compose.local.yml up -d --build",
    "compose:recreate": "docker compose -f ../../docker-compose.local.yml up -d --build --force-recreate rag-api",
    "compose:down": "docker compose -f ../../docker-compose.local.yml down",
    "compose:logs": "docker compose -f ../../docker-compose.local.yml logs -f rag-api",
    "compose:gpu:up": "docker compose -f ../../docker-compose.local.yml -f ../../docker-compose.gpu.yml up -d --build",
    "compose:gpu:down": "docker compose -f ../../docker-compose.local.yml -f ../../docker-compose.gpu.yml down",
    "compose:gpu:logs": "docker compose -f ../../docker-compose.local.yml -f ../../docker-compose.gpu.yml logs -f rag-api ollama",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "test": "jest"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/typeorm": "^11.0.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "ollama": "^0.6.3",
    "pg": "^8.21.0",
    "pgvector": "^0.3.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "typeorm": "^1.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.0"
  }
}
